{
  "manifest_version": 3,
  "name": "GSC URL Inspection Helper",
  "version": "0.1.0",
  "description": "Batch submit URLs to Google Search Console URL inspection and request indexing when needed.",
  "action": {
    "default_title": "GSC URL Inspection Helper"
  },
  "permissions": [
    "activeTab",
    "debugger",
    "sidePanel",
    "tabs",
    "storage"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://search.google.com/search-console/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
